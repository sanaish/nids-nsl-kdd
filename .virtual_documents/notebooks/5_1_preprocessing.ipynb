print("All unique labels in training set:")
print(sorted(train_df["label"].unique()))


y_train = map_binary_labels(train_df)
y_test  = map_binary_labels(test_df)

# Class balance
fig, axes = plt.subplots(1, 2, figsize=(9, 4))
for ax, (y, title) in zip(axes, [(y_train, "Train"), (y_test, "Test")]):
    counts = y.value_counts().sort_index()
    ax.bar(["Normal (0)", "Attack (1)"], counts.values,
           color=["#55A868", "#C44E52"])
    ax.set_title(f"{title} — Class Balance")
    ax.set_ylabel("Count")
    for i, v in enumerate(counts.values):
        ax.text(i, v + 300, f"{v:,}", ha="center", fontsize=10)

plt.tight_layout()
plt.savefig("../reports/class_balance.png", dpi=150)
plt.show()

print(f"Train — Normal: {(y_train==0).sum():,}  Attack: {(y_train==1).sum():,}")
print(f"Test  — Normal: {(y_test==0).sum():,}   Attack: {(y_test==1).sum():,}")





X_train = train_df.drop("label", axis=1).copy()
X_test  = test_df.drop("label",  axis=1).copy()

X_train_enc, X_test_enc, encoders = encode_categoricals(X_train, X_test)

# Show before vs after for protocol_type
print("\nprotocol_type — before:", train_df["protocol_type"].unique())
print("protocol_type — after: ", X_train_enc["protocol_type"].unique())





X_train_scaled, X_test_scaled, scaler = normalise(X_train_enc, X_test_enc)

# Confirm range
print(f"Train min: {X_train_scaled.min().min():.4f}  "
      f"max: {X_train_scaled.max().max():.4f}")
print(f"Test  min: {X_test_scaled.min().min():.4f}  "
      f"max: {X_test_scaled.max().max():.4f}")
print()
print("Note: test max may slightly exceed 1.0 if test contains values "
      "outside the training range — this is expected.")


# Distribution of src_bytes before vs after scaling
fig, axes = plt.subplots(1, 2, figsize=(10, 4))

axes[0].hist(train_df["src_bytes"].clip(upper=5000), bins=50,
             color="#4C72B0", edgecolor="white")
axes[0].set_title("src_bytes — Before Scaling (clipped at 5000)")
